// Place your key bindings in this file to override the defaultsauto[]
[
    {
        "key": "ctrl+shift+e",
        "command": "workbench.action.closeSidebar",
        "when": "sideBarVisible"
    },
    {
        "key": "ctrl+shift+e",
        "command": "workbench.files.action.focusFilesExplorer",
        "when": "!explorerViewletVisible"
    },
    //Disable default implementation
    {
        "key": "ctrl+n",
        "command": "vscode-neovim.send",
        "when": "editorTextFocus && neovim.init && neovim.mode != insert",
        "args": "<c-n>"
    },
    {
        "key": "ctrl+p",
        "command": "vscode-neovim.send",
        "when": "editorTextFocus && neovim.init && neovim.mode != insert",
        "args": "<c-p>"
    },
    // Move lines up and down
    {
        "key": "alt+j",
        "command": "editor.action.moveLinesDownAction",
        "when": "editorTextFocus && !editorReadonly"
    },
    {
        "key": "alt+k",
        "command": "editor.action.moveLinesUpAction",
        "when": "editorTextFocus && !editorReadonly"
    },
    //better scroll
    {
        "key": "ctrl+u",
        "command": "-vscode-neovim.ctrl-u",
        "when": "editorTextFocus && neovim.ctrlKeysNormal.u && neovim.init && neovim.mode != 'insert' && editorLangId not in 'neovim.editorLangIdExclusions'"
    },
    {
        "key": "ctrl+d",
        "command": "-vscode-neovim.ctrl-d",
        "when": "editorTextFocus && neovim.ctrlKeysNormal.d && neovim.init && neovim.mode != 'insert' && editorLangId not in 'neovim.editorLangIdExclusions'"
    },
    {
        "key": "ctrl+u",
        "command": "vscode-neovim.send",
        "when": "editorTextFocus && neovim.ctrlKeysNormal.u && neovim.init && neovim.mode != 'insert' && editorLangId not in 'neovim.editorLangIdExclusions'",
        "args": "<C-u>"
    },
    {
        "key": "ctrl+d",
        "command": "vscode-neovim.send",
        "when": "editorTextFocus && neovim.ctrlKeysNormal.d && neovim.init && neovim.mode != 'insert' && editorLangId not in 'neovim.editorLangIdExclusions'",
        "args": "<C-d>"
    },
    // Switch tabs
    {
        "key": "shift+h",
        "command": "workbench.action.previousEditorInGroup",
        "when": "!sideBarFocus && !panelFocus && !editorTextFocus"
    },
    {
        "key": "shift+l",
        "command": "workbench.action.nextEditorInGroup",
        "when": "!sideBarFocus && !panelFocus && !editorTextFocus"
    },
    // Terminal
    {
        "key": "ctrl+shift+/",
        "command": "workbench.action.terminal.newWithProfile"
    },
    {
        "key": "ctrl+/",
        "command": "workbench.action.terminal.toggleTerminal",
        "when": "terminal.active"
    },
    // Panel/Sidebar navigation
    {
        "key": "escape",
        "command": "workbench.action.togglePanel",
        "when": "panelFocus && !terminalFocus"
    },
    {
        "key": "ctrl+`",
        "command": "workbench.action.toggleMaximizedPanel",
        "when": "panelFocus"
    },
    {
        "key": "ctrl+k",
        "command": "workbench.action.focusActiveEditorGroup",
        "when": "panelFocus"
    },
    {
        "key": "ctrl+h",
        "command": "workbench.action.focusActiveEditorGroup",
        "when": "sideBarFocus"
    },
    // whichkey
    {
        "key": "ctrl+shift+space",
        "command": "whichkey.show",
        "when": "!editorTextFocus"
    },
    // Switch git diff editor
    {
        "key": "ctrl+h",
        "command": "diffEditor.switchSide",
        "when": "editorTextFocus && neovim.init && neovim.mode != insert && isInDiffEditor && isInDiffRightEditor"
    },
    {
        "key": "ctrl+l",
        "command": "diffEditor.switchSide",
        "when": "editorTextFocus && neovim.init && neovim.mode != insert && isInDiffEditor && isInDiffLeftEditor"
    },
    // Remove conflicts keybindings
    {
        "key": "ctrl+j",
        "command": "-workbench.action.togglePanel"
    }
]